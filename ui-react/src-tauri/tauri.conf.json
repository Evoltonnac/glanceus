{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Glancier",
    "version": "0.1.0",
    "identifier": "com.glancier.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "Glancier",
                "width": 1200,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
    },
    "plugins": {
        "shell": {
            "open": true
        }
    }
}
